{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://brain.pipadacapital.com/engineering-os/schemas/qa-review.schema.json",
  "title": "QA Review (Stage 5)",
  "type": "object",
  "required": ["schema_version", "req_id", "actor", "ts", "verdict", "gates", "test_runs"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "req_id": { "type": "string" },
    "actor": { "type": "string", "const": "qa-agent" },
    "actor_persona": { "type": "string", "const": "tanvi" },
    "ts": { "type": "string", "format": "date-time" },
    "verdict": { "enum": ["PASS", "FAIL", "NEEDS-MORE-INFO"] },
    "gates": {
      "type": "object",
      "required": [
        "coverage_above_70",
        "real_network_smoke_captured",
        "contract_tests_present",
        "metric_registry_parity",
        "operational_readiness_green",
        "mutation_tests_present_on_high_stakes_paths"
      ],
      "properties": {
        "coverage_above_70": { "type": "boolean" },
        "real_network_smoke_captured": { "type": "boolean" },
        "contract_tests_present": { "type": "boolean" },
        "metric_registry_parity": { "type": "boolean" },
        "operational_readiness_green": { "type": "boolean" },
        "mutation_tests_present_on_high_stakes_paths": { "type": "boolean" },
        "no_flaky_tests": { "type": "boolean" }
      }
    },
    "test_runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "command", "actual_output_snippet", "passed"],
        "properties": {
          "category": {
            "enum": ["unit", "integration", "contract", "e2e-web", "e2e-mobile", "load", "real-network-smoke", "mutation"]
          },
          "command": { "type": "string" },
          "actual_output_snippet": { "type": "string" },
          "expected": { "type": "string" },
          "passed": { "type": "boolean" }
        }
      }
    },
    "operational_readiness_checklist": {
      "type": "object",
      "properties": {
        "root_handler": { "type": "boolean" },
        "health_endpoint": { "type": "boolean" },
        "port_selection": { "type": "boolean" },
        "env_var_validation": { "type": "boolean" },
        "native_deps_ok": { "type": "boolean" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "evidence"],
        "properties": {
          "severity": { "enum": ["block", "high", "medium", "low"] },
          "title": { "type": "string" },
          "evidence": { "type": "string" },
          "responsible_persona": { "enum": ["vikram", "ananya", "karan", "maya"] }
        }
      }
    }
  },
  "additionalProperties": false
}
