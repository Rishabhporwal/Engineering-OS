{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://brain.pipadacapital.com/engineering-os/schemas/architecture.schema.json",
  "title": "Architecture Plan (Stage 2)",
  "type": "object",
  "required": [
    "schema_version",
    "req_id",
    "actor",
    "ts",
    "context",
    "proposed_solution",
    "paradigm",
    "paradigm_justification",
    "api_design",
    "data_model_changes",
    "event_model",
    "observability_plan",
    "test_strategy",
    "risks",
    "alternatives_considered",
    "tracks"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "req_id": { "type": "string" },
    "actor": { "type": "string", "const": "architect" },
    "ts": { "type": "string", "format": "date-time" },
    "context": { "type": "string", "description": "What we're solving and why now." },
    "proposed_solution": { "type": "string" },
    "diagram_mermaid": { "type": "string", "description": "Mermaid diagram source." },
    "paradigm": { "enum": ["sql", "ml", "small_llm", "frontier_llm"] },
    "paradigm_justification": { "type": "string", "minLength": 20 },
    "api_design": {
      "type": "object",
      "properties": {
        "grpc_protos_added_or_changed": { "type": "array", "items": { "type": "string" } },
        "trpc_procedures_added_or_changed": { "type": "array", "items": { "type": "string" } },
        "mcp_tools_added_or_changed": { "type": "array", "items": { "type": "string" } },
        "rest_endpoints_added_or_changed": { "type": "array", "items": { "type": "string" } },
        "breaking_changes": { "type": "array", "items": { "type": "string" } },
        "versioning_strategy": { "type": "string" }
      }
    },
    "data_model_changes": {
      "type": "object",
      "properties": {
        "postgres_tables_added": { "type": "array", "items": { "type": "string" } },
        "postgres_tables_changed": { "type": "array", "items": { "type": "string" } },
        "clickhouse_tables_added": { "type": "array", "items": { "type": "string" } },
        "materialized_views_added": { "type": "array", "items": { "type": "string" } },
        "migration_plan": { "type": "string" },
        "rls_policies": { "type": "array", "items": { "type": "string" } },
        "indexes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "event_model": {
      "type": "object",
      "properties": {
        "topics_added": { "type": "array", "items": { "type": "string" } },
        "topics_changed": { "type": "array", "items": { "type": "string" } },
        "partition_key": { "type": "string", "const": "workspace_id" },
        "exactly_once_strategy": { "type": "string" }
      }
    },
    "single_primitive_sweep": {
      "type": "object",
      "required": ["audience_builder", "consent", "decision_log", "notifications", "attribution", "identity"],
      "properties": {
        "audience_builder": { "enum": ["reused", "extended", "violated-needs-discussion"] },
        "consent": { "enum": ["reused", "extended", "violated-needs-discussion"] },
        "decision_log": { "enum": ["reused", "extended", "violated-needs-discussion"] },
        "notifications": { "enum": ["reused", "extended", "violated-needs-discussion"] },
        "attribution": { "enum": ["reused", "extended", "violated-needs-discussion"] },
        "identity": { "enum": ["reused", "extended", "violated-needs-discussion"] }
      }
    },
    "multitenancy_enforcement": {
      "type": "object",
      "required": ["jwt", "service_side", "db_rls", "kafka_envelope"],
      "properties": {
        "jwt": { "type": "boolean" },
        "service_side": { "type": "boolean" },
        "db_rls": { "type": "boolean" },
        "kafka_envelope": { "type": "boolean" }
      }
    },
    "observability_plan": {
      "type": "object",
      "required": ["metrics", "logs", "traces", "alarms", "dashboards"],
      "properties": {
        "metrics": { "type": "array", "items": { "type": "string" } },
        "logs": { "type": "array", "items": { "type": "string" } },
        "traces": { "type": "array", "items": { "type": "string" } },
        "alarms": { "type": "array", "items": { "type": "string" } },
        "dashboards": { "type": "array", "items": { "type": "string" } }
      }
    },
    "test_strategy": {
      "type": "object",
      "required": ["unit", "integration", "contract", "real_network_smoke"],
      "properties": {
        "unit": { "type": "string" },
        "integration": { "type": "string" },
        "contract": { "type": "string" },
        "e2e": { "type": "string" },
        "load": { "type": "string" },
        "real_network_smoke": { "type": "string" },
        "mutation_testing_targets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "security_considerations": { "type": "string" },
    "india_context": { "type": "string" },
    "region_adapter_impact": { "type": "string" },
    "cost_estimate": {
      "type": "object",
      "required": ["llm_tokens_per_day", "inr_per_month_at_expected_load"],
      "properties": {
        "llm_tokens_per_day": { "type": "integer" },
        "inr_per_month_at_expected_load": { "type": "number" },
        "assumed_load": { "type": "string" }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk", "severity"],
        "properties": {
          "risk": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "alternatives_considered": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["alternative", "why_rejected"],
        "properties": {
          "alternative": { "type": "string" },
          "why_rejected": { "type": "string" }
        }
      }
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["track_id", "owner_persona", "task_list"],
        "properties": {
          "track_id": { "type": "string", "description": "e.g., 'be-recover-route'" },
          "owner_persona": { "enum": ["vikram", "ananya", "karan", "maya"] },
          "task_list": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "dependencies": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "additionalProperties": false
}
