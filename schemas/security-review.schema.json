{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://engineering-os.dev/engineering-os/schemas/security-review.schema.json",
  "title": "Security Review (Stage 4)",
  "type": "object",
  "required": [
    "schema_version",
    "req_id",
    "actor",
    "ts",
    "verdict",
    "gates",
    "findings",
    "scan_results"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "req_id": { "type": "string" },
    "actor": { "type": "string", "const": "security-reviewer" },
    "actor_persona": { "type": "string", "const": "security-reviewer" },
    "ts": { "type": "string", "format": "date-time" },
    "verdict": { "enum": ["PASS", "BOUNCE"] },
    "surface_scope": {
      "type": "object",
      "description": "Change-class fast-path: declare which surfaces the change touches. A surface marked false legitimately makes its gate(s) out-of-scope (omit them below). ALWAYS-ON checks (vuln scans, secrets, supply-chain, input-validation, minor-units/no-float for money-derived code) run regardless. A pure library/registry change has every flag false.",
      "properties": {
        "api": { "type": "boolean" },
        "outbound_channel": { "type": "boolean" },
        "connector": { "type": "boolean" },
        "pii": { "type": "boolean" },
        "money_movement": { "type": "boolean" },
        "agent_action": { "type": "boolean" },
        "library_only": { "type": "boolean", "description": "true = pure library/metric/util change; all surface gates + the compliance section are N/A (out of scope)." }
      }
    },
    "gates": {
      "type": "object",
      "required": [
        "no_critical",
        "no_high"
      ],
      "properties": {
        "no_critical": { "type": "boolean" },
        "no_high": { "type": "boolean" },
        "no_compliance_violation": { "type": "boolean", "description": "No violation of the product's compliance regime as declared in the Product Canon's COMPLIANCE.md." },
        "mutation_endpoints_guarded": { "type": "boolean" },
        "mcp_tools_tenant_checked": { "type": "boolean" },
        "connectors_token_encrypted": { "type": "boolean" },
        "pii_not_in_logs": { "type": "boolean" },
        "negative_control_confirmed": { "type": "boolean", "description": "tenancy/auth tests run under the REAL (non-BYPASSRLS) security context; every probe fails when the protection is removed (O11). Validated by tools/validity_check.py." }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "evidence", "recommended_remediation"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "enum": ["critical", "high", "medium", "low", "info"] },
          "title": { "type": "string" },
          "category": {
            "enum": [
              "auth", "authorization", "input-validation", "secrets",
              "multitenancy", "xss", "csrf", "rate-limiting",
              "compliance-data-protection", "compliance-residency", "compliance-retention",
              "compliance-consent", "compliance-channel-window",
              "owasp-top10", "masvs-l1", "masvs-l2", "supply-chain", "other"
            ]
          },
          "evidence": { "type": "string" },
          "recommended_remediation": { "type": "string" },
          "responsible_persona": { "enum": ["backend-developer", "frontend-web-developer", "mobile-developer", "intelligence-engineer", "architect", "platform-devops"] },
          "bounce_target_stage": { "type": "integer", "minimum": 1, "maximum": 8 }
        }
      }
    },
    "scan_results": {
      "type": "object",
      "properties": {
        "pnpm_audit": { "type": "string" },
        "snyk": { "type": "string" },
        "bandit": { "type": "string" },
        "safety": { "type": "string" },
        "pip_audit": { "type": "string" },
        "trivy": { "type": "string" },
        "owasp_dep_check": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
