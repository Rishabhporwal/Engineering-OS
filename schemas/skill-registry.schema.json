{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://engineering-os.dev/engineering-os/schemas/skill-registry.schema.json",
  "title": "Skill Registry",
  "description": "Index of every curated skill known to the Engineering OS, with role mapping.",
  "type": "object",
  "required": ["schema_version", "generated_at", "skills"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_root": { "type": "string", "description": "Where curated skills live (canonical)." },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "domain", "primary_roles", "shared_with"],
        "properties": {
          "id": { "type": "string", "description": "Folder name in skills/." },
          "description": { "type": "string" },
          "domain": {
            "enum": [
              "ARCH", "BE", "FE-W", "FE-M", "DATA", "AI", "SEC",
              "OBS", "TEST", "PERF", "OPS", "INTG", "DISC", "PROD"
            ]
          },
          "primary_roles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["CTOA", "ARC", "BE", "FEW", "FEM", "AIE", "SEC", "QA", "OPS", "PM", "DYN", "ALL"]
            }
          },
          "shared_with": {
            "type": "array",
            "items": {
              "enum": ["CTOA", "ARC", "BE", "FEW", "FEM", "AIE", "SEC", "QA", "OPS", "PM", "DYN", "ALL"]
            }
          },
          "exposed_as_slash_command": { "type": "boolean", "default": true },
          "auto_load_triggers": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Keywords / patterns that trigger auto-load."
          },
          "deprecated": { "type": "boolean", "default": false }
        }
      }
    }
  },
  "additionalProperties": false
}
