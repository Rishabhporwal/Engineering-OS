{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://engineering-os.dev/engineering-os/schemas/cto-advisor-review.schema.json",
  "title": "CTO Advisor Review (Stage 1 or Stage 6)",
  "type": "object",
  "required": ["schema_version", "req_id", "stage", "actor", "ts", "decision"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "req_id": { "type": "string" },
    "stage": { "enum": [1, 6] },
    "actor": { "type": "string", "const": "cto-advisor" },
    "ts": { "type": "string", "format": "date-time" },
    "made_requirements_less_dumb": {
      "type": "object",
      "properties": {
        "could_delete": { "type": "array", "items": { "type": "string" } },
        "could_simplify": { "type": "array", "items": { "type": "string" } },
        "could_defer": { "type": "array", "items": { "type": "string" } }
      }
    },
    "personas_spawned": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": { "type": "string" },
      "description": "Stage 1 only. Names of the 0-2 personas spawned (by complexity)."
    },
    "persona_synthesis": {
      "type": "string",
      "description": "Stage 1 only. Short synthesis of persona inputs."
    },
    "paradigm_recommendation": {
      "enum": ["sql", "ml", "small_llm", "frontier_llm"],
      "description": "Stage 1 first-pass paradigm read; Architect may refine."
    },
    "region_context_check": {
      "type": "object",
      "description": "Did this requirement consider the product's region/locale and compliance context (per the Product Canon's COMPLIANCE.md and the RegionAdapter seam)?",
      "properties": {
        "region_economics_impact": { "type": "string", "description": "Region-varying economics that change the design (via the RegionAdapter seam)." },
        "compliance_regime_impact": { "type": "string", "description": "Impact on the product's compliance regime (data-protection, residency, retention, consent, channel rules)." },
        "money_metric_impact": { "type": "string", "description": "Impact on financial metrics or money handling (minor units + currency_code)." },
        "locale_impact": { "type": "string", "description": "Locale/format/i18n/RTL impact." }
      }
    },
    "challenge": {
      "type": "object",
      "description": "Present only if decision is CHALLENGE-BACK.",
      "required": ["understood", "concern", "risk", "alternative", "decision_needed"],
      "properties": {
        "understood": { "type": "string" },
        "concern": { "type": "string" },
        "risk": { "type": "string" },
        "alternative": { "type": "string" },
        "decision_needed": { "type": "string" }
      }
    },
    "final_review": {
      "type": "object",
      "description": "Stage 6 only.",
      "properties": {
        "requirement_alignment": { "enum": ["PASS", "FAIL"] },
        "paradigm_audit": { "enum": ["PASS", "FAIL"] },
        "architecture_quality": { "enum": ["PASS", "FAIL"] },
        "code_quality": { "enum": ["PASS", "FAIL"] },
        "security_summary": { "type": "string" },
        "qa_summary": { "type": "string" },
        "observability_complete": { "type": "boolean" },
        "cost_estimate_held": { "type": "boolean" },
        "risks_remaining": { "type": "array", "items": { "type": "string" } },
        "production_readiness_assessment": { "type": "string" },
        "recommendation": { "enum": ["APPROVE", "APPROVE-WITH-CAVEATS", "REJECT"] }
      }
    },
    "decision": { "enum": ["ADVANCE", "CHALLENGE-BACK", "KILL", "BOUNCE", "PASS", "FAIL"] },
    "rationale": { "type": "string" },
    "bounce_target_stage": { "type": "integer", "minimum": 1, "maximum": 8 }
  },
  "additionalProperties": false
}
