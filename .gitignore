# Engineering OS — gitignore
# .engineering-os/ IS committed — it's the shared memory. Do not exclude it.

# OS cruft
.DS_Store
Thumbs.db

# Editor cruft
.vscode/
.idea/
*.swp
*.swo
*~

# Local secrets (NEVER commit)
.env
.env.local
.env.*.local
.envrc

# Node / Python (in case operators experiment in this repo)
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Large unreviewed artifacts (use git LFS if needed)
.engineering-os/runs/**/*.bin
.engineering-os/runs/**/*.zip
.engineering-os/runs/**/*.tar.gz

# State file backups (kept locally only — short-lived recovery)
.engineering-os/state/*.bak.*
